# Villages Reborn Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Required: LLM API Key for AI-driven village features
# Get your API key from your LLM provider (OpenAI, Anthropic, etc.)
VILLAGESREBORN_LLM_API_KEY=your_api_key_here

# Optional: Development mode (true/false)
# Enables additional logging and development features
VILLAGESREBORN_DEVELOPMENT_MODE=false

# Optional: Log level (0=ERROR, 1=WARN, 2=INFO, 3=DEBUG)
# Controls verbosity of logging output
VILLAGESREBORN_LOG_LEVEL=1

# Optional: Encryption key for secure configuration
# Generate with: java -cp villagesreborn.jar com.beeny.villagesreborn.core.util.SecurityUtil generateKey
# If not provided, a development key will be used (NOT secure for production)
VILLAGESREBORN_ENCRYPTION_KEY=

# Optional: Custom configuration file path
# If not set, will look for villagesreborn.properties in current directory
VILLAGESREBORN_CONFIG_FILE=